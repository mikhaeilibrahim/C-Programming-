int max_zeros(unsigned int x)
{
    int count=0,max=0,flag=0,i;
    for(i=0;i<=31;i++)
    {
        if(((x>>i)&1))
        {
              if(count>max)
                {
                    max=count;
                }
            flag=1;
            count=0;
        }
        else if (flag==1)
        {
            count++;
        }

    }
    return max;
}
