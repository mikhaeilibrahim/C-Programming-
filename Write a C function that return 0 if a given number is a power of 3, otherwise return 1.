#include <stdio.h>
#include <stdlib.h>

int check_power_of_3(int num)
{
    int i;
    for(int i=num;i>1;i=i/3)
    {
       if(i%3 != 0)
       {
           return 1;
       }
    }
    return 0;
}


int main()
{
    int num;
  while(1)
  {
      printf("Enter Number to check power of 3 or no\n");
      scanf("%d",&num);
      int result=check_power_of_3(num);

      if(result==0)
      {
          printf("power of 3\n");
      }
      else
      {
          printf("Not power of 3\n");
      }
  }
    return 0;
}
