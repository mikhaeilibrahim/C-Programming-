#include <stdio.h>
#include <stdlib.h>

int main()
{
    signed int x,i;

    while(1)
    {
        printf("Enter Number to print it in binary\n");
        scanf("%d",&x);

        for(i=(sizeof(x)*8)-1;i>=0;i--)
        {
            if((x>>i)&1)
            {
                printf("1");
            }
            else
            {
                printf("0");
            }
        }
        printf("\n");
        printf("%d",sizeof(x));

    }

    return 0;
}
