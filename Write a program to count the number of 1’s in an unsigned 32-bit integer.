int main()
{
    int x,ones,i,zeros;
    while(1)
    {
        ones=0;
        zeros=0;
        scanf("%d",&x);
        for(i=31;i>=0;i--)
        {
          if((x>>i)&1)
          {
              printf("1");
              ones++;
          }
          else
          {
              printf("0");
              zeros++;
          }
        }
        printf("\n");
        printf("ones=%d zeros=%d\n",ones,zeros);
    }
}
