int main()
{
    int x,c;

    while(1)
    {
        printf("Enter number and character\n");
        fflush(stdin);
        scanf("%d%c",&x,&c);
        if(x%2==0)
        {
            printf("%c\n",c);
        }
        else
        {
            if(c>='A' && c<='Z')
            {
                c='a'-'A'+c;
            }
            else if(c>='a' && c<='z')
            {
                c=c-('a'-'A');
            }
            printf("%c\n",c);
        }

    }
    return 0;
}
