void print_binary(unsigned int n)
{
    int i,flag=0;
    for(i=(sizeof(n)*8)-1; i>=0; i--)
    {
        if((n>>i)&1)
        {
            flag=1;
            printf("1");
        }
        else
        {
            if(flag==1)
            {
                printf("0");

            }
        }
    }
    printf("\n");
}
