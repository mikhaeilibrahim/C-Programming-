int main()
{
    int x,i,flag;
    while(1)
    {
        flag=0;
        scanf("%d",&x);
        for(i=31;i>=0;i--)
        {
          if((x>>i)&1)
          {
              printf("1");
              flag=1;
          }
          else
          {
              if(flag==1)
              {
                 printf("0");
              }
          }
        }
        printf("\n");
    }
}
