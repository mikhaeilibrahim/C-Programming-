#include <stdio.h>
#include <stdlib.h>

int max_xor(int n1,int n2)
{
    int i,j,max=0,loop=0,imax,jmax;
    if(n1>=n2)
    {
     swap(&n1,&n2);
    }

  for(i=n1;i<=n2;i++)
  {
     for(j=i;j<=n2;j++)
     {
         printf("%d  %d\n",i,j);
         int result=i^j;
         if(result>max)
         {
             max=result;
             imax=i;
             jmax=j;
         }
             loop++;
     }
  }
  printf("loop=%d\n",loop);
  printf("imax=%d   jmax=%d\n",imax,jmax);
  return max;
}


int main()
{
  int n1,n2,max;
  printf("Enter 2 numbers to get the max xor\n");
  scanf("%d%d",&n1,&n2);

printf("max_xor=%d\n", max_xor(n1,n2));

    return 0;
}
