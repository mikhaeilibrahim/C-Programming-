#include <stdio.h>
#include <stdlib.h>

int main()
{
    signed int x,i,sum;

    while(1)
    {
        printf("Enter Number to print it in binary\n");
        scanf("%d",&x);
        sum=0;

        for(i=15;i>=0;i--)
        {
            if((x>>i)&1)
            {
                printf("1");
                sum=sum+1;
            }
            else
            {
                printf("0");
            }
        }
        printf("\n");
        printf("number of ones=%d\n",sum);
        if(sum==1)
        {
            printf("%d is base of 2\n",x);
        }

    }

    return 0;
}
